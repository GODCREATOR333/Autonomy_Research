state = {
    'frame':    0,
    'playing':  False,
    'path':     [],
    'maze':     None,
    'success':  False,
    'maze_idx': 0,
}

last_rendered = [-1]

def render_frame(i):
    if not state['path']:
        return
    if i == last_rendered[0]:
        return
    last_rendered[0] = i
    draw_agent_panel(ax_agent, state['maze'], state['path'], i)
    draw_view_panel(ax_view,   state['maze'], state['path'], i)
    status      = 'SUCCESS ✓' if state['success'] else 'FAILED ✗'
    title_color = '#2ECC71'   if state['success'] else '#E74C3C'
    fig.suptitle(
        f"Maze {state['maze_idx']}  |  Step {i}/{len(state['path'])-1}  |  {status}",
        color=title_color, fontsize=13, y=0.99
    )
    fig.canvas.draw_idle()

timer = fig.canvas.new_timer(interval=200)

def timer_tick(*args):
    if state['playing']:
        if state['frame'] < len(state['path']) - 1:
            state['frame'] += 1
            render_frame(state['frame'])
        else:
            state['playing'] = False
            btn_play.label.set_text('▶')
            fig.canvas.draw_idle()

timer.add_callback(timer_tick)
timer.start()

def on_play(event):
    if state['playing']:
        state['playing'] = False
        btn_play.label.set_text('▶')
    else:
        state['playing'] = True
        btn_play.label.set_text('⏸')
    fig.canvas.draw_idle()

def on_back(event):
    state['playing'] = False
    btn_play.label.set_text('▶')
    state['frame'] = max(0, state['frame'] - 1)
    last_rendered[0] = -1
    render_frame(state['frame'])

def on_fwd(event):
    state['playing'] = False
    btn_play.label.set_text('▶')
    state['frame'] = min(len(state['path'])-1, state['frame'] + 1)
    last_rendered[0] = -1
    render_frame(state['frame'])

def on_run_all(event):
    """Run evaluation on all test mazes and print detailed stats"""
    print("\n🔄 Running evaluation on all test mazes...")
    global unseen_state_counter
    unseen_state_counter[0] = 0  # Reset counter
    results = evaluate_detailed(Q, test_mazes, n_eval=len(test_mazes))
    save_results_to_csv(results)
    print("✅ Evaluation complete")
    fig.canvas.draw_idle()

