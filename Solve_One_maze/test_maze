# --- Parameters ---
GRID_SIZE = 16
N_ACTIONS = 4
START     = (0, 0)
GOAL      = (GRID_SIZE-1, GRID_SIZE-1)
WINDOW_SIZE = 3
HALF_W = WINDOW_SIZE // 2

action_to_delta = {0: (-1,0), 1: (1,0), 2: (0,-1), 3: (0,1)}  # UP, DOWN, LEFT, RIGHT
action_to_arrow = {0: (0,-1), 1: (0,1), 2: (-1,0), 3: (1,0)}  # For visualization

COLOR_AGENT   = '#E74C3C'
COLOR_GOAL    = '#2ECC71'
COLOR_START   = '#3498DB'
COLOR_VISITED = '#F39C12'
BG            = '#1A1A2E'

# Global counter for unseen states
unseen_state_counter = [0]

# ----------------------------------------------------------------
# Helpers
# ----------------------------------------------------------------

def get_state(maze, pos):
    row, col = pos
    window = []

    for dr in range(-HALF_W, HALF_W + 1):
        for dc in range(-HALF_W, HALF_W + 1):
            r = row + dr
            c = col + dc

            if 0 <= r < GRID_SIZE and 0 <= c < GRID_SIZE:
                window.append(maze[r, c])
            else:
                window.append(1)  # Out of bounds = blocked

    dr_goal = int(np.sign(GOAL[0] - row))
    dc_goal = int(np.sign(GOAL[1] - col))

    return tuple(window) + (dr_goal, dc_goal)


def step(maze, pos, action):
    """Step function synced with training (includes progress reward for consistency)"""
    row, col = pos
    dr, dc   = action_to_delta[action]
    nr, nc   = row+dr, col+dc
    
    # Wall or boundary collision
    if nr < 0 or nr >= GRID_SIZE or nc < 0 or nc >= GRID_SIZE:
        return pos, -10.0, False
    if maze[nr, nc] == 1:
        return pos, -10.0, False
    
    # Goal reached
    if (nr, nc) == GOAL:
        return (nr, nc), +100.0, True
    
    # Progress-based reward (same as training)
    old_dist = abs(row - GOAL[0]) + abs(col - GOAL[1])
    new_dist = abs(nr - GOAL[0]) + abs(nc - GOAL[1])
    progress_reward = 0.5 * (old_dist - new_dist)
    step_penalty = -0.2
    
    return (nr, nc), step_penalty + progress_reward, False


def get_action_safe(Q, state, pos=None):
    """Get action with fallback for unseen states"""
    if state in Q:
        return np.argmax(Q[state])
    else:
        unseen_state_counter[0] += 1
        # Fallback: move toward goal direction
        if pos is not None:
            dr_goal = np.sign(GOAL[0] - pos[0])
            dc_goal = np.sign(GOAL[1] - pos[1])
            # Prefer movement that aligns with goal direction
            if dr_goal != 0:
                return 1 if dr_goal > 0 else 0  # DOWN or UP
            if dc_goal != 0:
                return 3 if dc_goal > 0 else 2  # RIGHT or LEFT
        return np.random.randint(N_ACTIONS)  # Last resort


def get_path(maze, Q):
    """Execute greedy policy with fallback for unseen states"""
    pos, path = START, [START]
    for _ in range(GRID_SIZE * GRID_SIZE * 4):  # Max steps
        state = get_state(maze, pos)
        action = get_action_safe(Q, state, pos)
        pos, _, done = step(maze, pos, action)
        path.append(pos)
        if done:
            return path, True
    return path, False


def get_ql_value_policy(maze, Q):
    """Extract value function and policy from Q-table for visualization"""
    V = np.full((GRID_SIZE, GRID_SIZE), np.nan)
    policy = np.full((GRID_SIZE, GRID_SIZE), -1)

    for r in range(GRID_SIZE):
        for c in range(GRID_SIZE):
            if maze[r, c] == 1:
                continue
            pos = (r, c)
            state = get_state(maze, pos)
            if state in Q:
                q_vals = Q[state]
                V[r, c] = np.max(q_vals)
                policy[r, c] = np.argmax(q_vals)
    return V, policy


def get_agent_view(maze, pos):
    """Extract 3x3 local view for visualization"""
    row, col = pos
    view = np.ones((WINDOW_SIZE, WINDOW_SIZE))
    for i, dr in enumerate(range(-HALF_W, HALF_W + 1)):
        for j, dc in enumerate(range(-HALF_W, HALF_W + 1)):
            r, c = row + dr, col + dc
            if 0 <= r < GRID_SIZE and 0 <= c < GRID_SIZE:
                view[i, j] = maze[r, c]
    return view


def evaluate_detailed(Q, mazes, n_eval=None):
    """Return detailed metrics beyond just success rate"""
    if n_eval is None:
        n_eval = len(mazes)
    
    results = []
    local_unseen = [0]  # Local counter for this evaluation
    
    for i in range(n_eval):
        maze = mazes[i]
        pos = START
        path = [pos]
        visited_states = set()
        
        for step_num in range(GRID_SIZE * GRID_SIZE * 4):
            state = get_state(maze, pos)
            if state not in Q:
                local_unseen[0] += 1
            visited_states.add(state)
            
            action = get_action_safe(Q, state, pos)
            pos, _, done = step(maze, pos, action)
            path.append(pos)
            
            if done:
                break
        
        # Compute metrics
        final_dist = abs(pos[0]-GOAL[0]) + abs(pos[1]-GOAL[1])
        results.append({
            'maze_idx': i,
            'success': done,
            'steps': len(path)-1,
            'final_dist': final_dist,
            'unique_states': len(visited_states)
        })
    
    # Aggregate stats
    successes = sum(1 for r in results if r['success'])
    successful_steps = [r['steps'] for r in results if r['success']]
    failed_dists = [r['final_dist'] for r in results if not r['success']]
    
    print(f"\n📊 Detailed Evaluation ({n_eval} mazes):")
    print(f"   Success Rate: {successes}/{n_eval} = {100*successes/n_eval:.1f}%")
    if successful_steps:
        print(f"   Avg Steps (success): {np.mean(successful_steps):.1f} ± {np.std(successful_steps):.1f}")
    if failed_dists:
        print(f"   Avg Final Distance (fail): {np.mean(failed_dists):.1f}")
    print(f"   Unseen States Encountered: {local_unseen[0]}")
    
    # After evaluate_detailed(), add:
    failed_mazes = [r['maze_idx'] for r in results if not r['success']]
    if failed_mazes:
        print(f"\n🔍 First 5 failed maze indices: {failed_mazes[:5]}")
        print("💡 Try visualizing these specific mazes with the slider to debug")
        
    return results


def save_results_to_csv(results, filename='eval_results.csv'):
    """Save evaluation results to CSV for analysis"""
    if not results:
        return
    with open(filename, 'w', newline='') as f:
        writer = csv.DictWriter(f, fieldnames=results[0].keys())
        writer.writeheader()
        writer.writerows(results)
    print(f"💾 Results saved to {filename}")


# ----------------------------------------------------------------
# Maze image cache — build RGB array once per maze
# ----------------------------------------------------------------

_maze_img_cache = {}

def get_maze_base_img(maze):
    key = id(maze)
    if key not in _maze_img_cache:
        img = np.zeros((GRID_SIZE, GRID_SIZE, 3), dtype=np.float32)
        for r in range(GRID_SIZE):
            for c in range(GRID_SIZE):
                if maze[r, c] == 1:
                    img[r, c] = [0.17, 0.24, 0.31]   # obstacle
                else:
                    img[r, c] = [0.93, 0.94, 0.95]   # free
        img[START[0], START[1]] = [0.20, 0.60, 0.86]  # start
        img[GOAL[0],  GOAL[1]]  = [0.18, 0.80, 0.44]  # goal
        _maze_img_cache[key] = img
    return _maze_img_cache[key].copy()

