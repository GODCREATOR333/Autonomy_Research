# --- Parameters ---
GRID_SIZE = 16
N_ACTIONS = 4
START     = (0, 0)
GOAL      = (GRID_SIZE-1, GRID_SIZE-1)
WINDOW_SIZE = 3
HALF_W = WINDOW_SIZE // 2


action_to_delta = {0: (-1,0), 1: (1,0), 2: (0,-1), 3: (0,1)}
action_to_arrow = {0: (0,-1), 1: (0,1), 2: (-1,0), 3: (1,0)}

