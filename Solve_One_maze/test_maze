# ----------------------------------------------------------------
# Frame state
# ----------------------------------------------------------------

state = {
    'frame':    0,
    'playing':  False,
    'path':     [],
    'maze':     None,
    'success':  False,
    'maze_idx': 0,
}

last_rendered = [-1]

def render_frame(i):
    if not state['path']:
        return
    if i == last_rendered[0]:
        return
    last_rendered[0] = i
    draw_agent_panel(ax_agent, state['maze'], state['path'], i)
    draw_view_panel(ax_view,   state['maze'], state['path'], i)
    status      = 'SUCCESS ✓' if state['success'] else 'FAILED ✗'
    title_color = '#2ECC71'   if state['success'] else '#E74C3C'
    fig.suptitle(
        f"Maze {state['maze_idx']}  |  Step {i}/{len(state['path'])-1}  |  {status}",
        color=title_color, fontsize=13, y=0.99
    )
    fig.canvas.draw_idle()

timer = fig.canvas.new_timer(interval=200)

def timer_tick(*args):
    if state['playing']:
        if state['frame'] < len(state['path']) - 1:
            state['frame'] += 1
            render_frame(state['frame'])
        else:
            state['playing'] = False
            btn_play.label.set_text('▶')
            fig.canvas.draw_idle()

timer.add_callback(timer_tick)
timer.start()

def on_play(event):
    if state['playing']:
        state['playing'] = False
        btn_play.label.set_text('▶')
    else:
        state['playing'] = True
        btn_play.label.set_text('⏸')
    fig.canvas.draw_idle()

def on_back(event):
    state['playing'] = False
    btn_play.label.set_text('▶')
    state['frame'] = max(0, state['frame'] - 1)
    last_rendered[0] = -1
    render_frame(state['frame'])

def on_fwd(event):
    state['playing'] = False
    btn_play.label.set_text('▶')
    state['frame'] = min(len(state['path'])-1, state['frame'] + 1)
    last_rendered[0] = -1
    render_frame(state['frame'])

btn_play.on_clicked(on_play)
btn_back.on_clicked(on_back)
btn_fwd.on_clicked(on_fwd)

# ----------------------------------------------------------------
# Main run_maze
# ----------------------------------------------------------------

def run_maze(idx):
    # idx   = int(idx)
    idx = 10
    maze  = test_mazes[idx]
    path, success = get_path(maze, Q)

    V_vi,  pol_vi = vi_results[idx]['V'], vi_results[idx]['policy']
    V_ql,  pol_ql = get_ql_value_policy(maze, Q)

    state['frame']    = 0
    state['path']     = path
    state['maze']     = maze
    state['success']  = success
    state['maze_idx'] = idx
    state['playing']  = True
    last_rendered[0]  = -1
    btn_play.label.set_text('⏸')

    status = 'SUCCESS ✓' if success else 'FAILED ✗'
    print(f"Maze {idx} | {status} | {len(path)} steps")

    reset_agent_panel()

    draw_value_panel(ax_vi_val, im_vi, V_vi, maze, 'Value Function  (VI — Optimal)')
    draw_value_panel(ax_ql_val, im_ql, V_ql, maze, 'Value Function  (QL — Learned)')
    draw_policy_panel(ax_vi_pol, pol_vi, maze, 'Optimal Policy (VI)')
    draw_policy_panel(ax_ql_pol, pol_ql, maze, 'Learned Policy (QL)')

    render_frame(0)

slider.on_changed(run_maze)
run_maze(0)
plt.show()