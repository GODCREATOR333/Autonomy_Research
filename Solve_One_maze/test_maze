# Persistent handles for agent panel
_agent_im_handle = [None]
_agent_circle    = [None]
_agent_ax_ready  = [False]

def reset_agent_panel():
    _agent_ax_ready[0] = False

def draw_agent_panel(ax, maze, path, step_idx):
    pos = path[min(step_idx, len(path)-1)]

    if not _agent_ax_ready[0]:
        ax.clear()
        ax.set_facecolor(BG)
        ax.axis('off')
        ax.set_xlim(-0.5, GRID_SIZE-0.5)
        ax.set_ylim(GRID_SIZE-0.5, -0.5)
        ax.set_aspect('equal', adjustable='box')

        # Base maze image
        img = get_maze_base_img(maze)
        _agent_im_handle[0] = ax.imshow(
            img,
            extent=[-0.5, GRID_SIZE-0.5, GRID_SIZE-0.5, -0.5],
            interpolation='nearest',
            zorder=0,
            aspect='equal'
        )

        # Draw grid once
        for i in range(GRID_SIZE + 1):
            ax.axhline(i - 0.5, color='#BDC3C7', linewidth=0.35, zorder=1)
            ax.axvline(i - 0.5, color='#BDC3C7', linewidth=0.35, zorder=1)

        # Start + goal labels
        ax.text(START[1], START[0], 'S',
                ha='center', va='center',
                color='white', fontsize=9, fontweight='bold', zorder=4)
        ax.text(GOAL[1], GOAL[0], 'G',
                ha='center', va='center',
                color='white', fontsize=9, fontweight='bold', zorder=4)

        ax.set_title('Agent Navigation', color='white', fontsize=11, pad=6)

        # Agent marker
        circle = plt.Circle((pos[1], pos[0]), 0.35, color=COLOR_AGENT, zorder=5)
        ax.add_patch(circle)
        _agent_circle[0]   = circle
        _agent_ax_ready[0] = True

    else:
        # Update image with trail
        img = get_maze_base_img(maze)
        for i in range(min(step_idx, len(path))):
            r, c = path[i]
            if (r,c) != START and (r,c) != GOAL:
                img[r, c] = [0.95, 0.61, 0.07]   # visited
        _agent_im_handle[0].set_data(img)
        _agent_circle[0].center = (pos[1], pos[0])
    
    # Draw red X at final position if failed and at end of path
    if not state['success'] and step_idx == len(path)-1 and len(path) > 1:
        final_pos = path[-1]
        ax.plot([final_pos[1]-0.3, final_pos[1]+0.3], [final_pos[0]-0.3, final_pos[0]+0.3], 
                color='#E74C3C', linewidth=2.5, zorder=6)
        ax.plot([final_pos[1]-0.3, final_pos[1]+0.3], [final_pos[0]+0.3, final_pos[0]-0.3], 
                color='#E74C3C', linewidth=2.5, zorder=6)


def draw_view_panel(ax, maze, path, step_idx):
    ax.clear()
    ax.set_facecolor(BG)
    pos  = path[min(step_idx, len(path)-1)]
    view = get_agent_view(maze, pos)

    for i in range(WINDOW_SIZE):
        for j in range(WINDOW_SIZE):
            if i == 1 and j == 1:
                color = COLOR_AGENT
            elif view[i, j] == 1:
                color = '#2C3E50'
            else:
                color = '#ECF0F1'
            ax.add_patch(patches.Rectangle(
                (j-0.5, i-0.5), 1, 1,
                linewidth=1.5, edgecolor='#7F8C8D', facecolor=color
            ))

    dr_goal = int(np.sign(GOAL[0]-pos[0]))
    dc_goal = int(np.sign(GOAL[1]-pos[1]))
    ax.annotate('', xy=(1+dc_goal*0.7, 1+dr_goal*0.7), xytext=(1,1),
                arrowprops=dict(arrowstyle='->', color='#F1C40F', lw=2.5))

    ax.set_xlim(-0.5, WINDOW_SIZE - 0.5)
    ax.set_ylim(WINDOW_SIZE - 0.5, -0.5)
    ax.set_aspect('equal')
    ax.axis('off')
    ax.set_title("Agent's 3x3 View", color='white', fontsize=11, pad=6)


def draw_value_panel(ax, im_container, V, maze, title):
    V_display = np.where(
        np.array([[maze[r,c] for c in range(GRID_SIZE)]
                  for r in range(GRID_SIZE)]) == 1,
        np.nan, V
    )
    if im_container[0] is None:
        ax.set_facecolor(BG)
        im = ax.imshow(V_display, cmap='RdYlGn',
                       interpolation='nearest', aspect='equal')
        im_container[0] = im
        cb = plt.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
        cb.ax.tick_params(colors='white', labelsize=7)
        ax.tick_params(colors='white', labelsize=7)
    else:
        im_container[0].set_data(V_display)
        vmin = np.nanmin(V_display)
        vmax = np.nanmax(V_display)
        im_container[0].set_clim(vmin=vmin, vmax=vmax)
        for p in ax.patches:
            p.remove()

    for r in range(GRID_SIZE):
        for c in range(GRID_SIZE):
            if maze[r, c] == 1:
                ax.add_patch(patches.Rectangle(
                    (c-0.5, r-0.5), 1, 1,
                    facecolor='#2C3E50', linewidth=0, zorder=2
                ))
    ax.set_title(title, color='white', fontsize=11, pad=6)


def draw_policy_panel(ax, policy, maze, title):
    ax.clear()
    ax.set_facecolor(BG)
    ax.set_xlim(-0.5, GRID_SIZE-0.5)
    ax.set_ylim(GRID_SIZE-0.5, -0.5)
    ax.set_aspect('equal')

    for r in range(GRID_SIZE):
        for c in range(GRID_SIZE):
            ax.add_patch(patches.Rectangle(
                (c-0.5, r-0.5), 1, 1, linewidth=0.3,
                edgecolor='#4A4A6A',
                facecolor='#2C3E50' if maze[r,c]==1 else '#2E4057'
            ))

    for r in range(GRID_SIZE):
        for c in range(GRID_SIZE):
            if maze[r,c]==1 or (r,c)==GOAL or policy[r,c]==-1:
                continue
            du, dv = action_to_arrow[policy[r,c]]
            ax.quiver(c, r, du, dv, angles='xy', scale_units='xy', scale=2.5,
                      color='#F1C40F', width=0.004, headwidth=4)

    for pos_mark, col_mark, lbl in [(GOAL, COLOR_GOAL, 'G'), (START, COLOR_START, 'S')]:
        ax.add_patch(patches.Rectangle(
            (pos_mark[1]-0.5, pos_mark[0]-0.5), 1, 1,
            facecolor=col_mark, linewidth=0
        ))
        ax.text(pos_mark[1], pos_mark[0], lbl, ha='center', va='center',
                color='white', fontsize=9, fontweight='bold')

    ax.set_title(title, color='white', fontsize=11, pad=6)
    ax.tick_params(colors='white', labelsize=7)

